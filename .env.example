# Copy this file to `.env` and fill in values.

# LM Studio endpoint (OpenAI-compatible)
LMSTUDIO_API_BASE=http://192.168.6.233:1234/v1
LMSTUDIO_API_KEY_ENV=LMSTUDIO_API_KEY
LMSTUDIO_API_KEY=
LMSTUDIO_VISION_MODEL=qwen3-vl-32b-instruct
LMSTUDIO_REASONING_MODEL=google/gemma-3-27b
USE_LMSTUDIO_FOR_VISION=true
USE_LMSTUDIO_FOR_PAGEINDEX=true
USE_LMSTUDIO_FOR_ROUTER=true
USE_LANGCHAIN_OPENAI_WRAPPER=true
USE_OPENAI_FALLBACK_FOR_VISION=false
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_API_KEY_ENV=OPENAI_API_KEY
USE_GEMINI_FALLBACK_FOR_VISION=false
GEMINI_OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_API_KEY_ENV=GEMINI_API_KEY

# Optional direct keys (kept for compatibility)
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
